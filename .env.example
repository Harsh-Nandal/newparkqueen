# MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/parkqueen)
MONGODB_URI=

# SMTP transport used to send admin notifications + guest confirmations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Address emails are sent "from" — e.g. "The ParkQueen Hotel <no-reply@parkqueenhotels.com>"
SMTP_FROM=

# Inbox that receives contact/booking notifications (defaults to info@parkqueenhotels.com if unset)
ADMIN_NOTIFICATION_EMAIL=

# Secret used to sign admin-session JWTs — generate a long random string
JWT_SECRET=

# Bootstrap credentials consumed once by `npm run seed:admin` to create the first admin account
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
